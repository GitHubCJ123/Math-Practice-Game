{
  "name": "math-practice",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx watch server-dev.ts",
    "start": "concurrently --kill-others --raw --names \"web,api\" -c \"cyan,magenta\" \"vite\" \"tsx watch server-dev.ts\"",
    "dev:test": "cross-env VITE_NODE_ENV=test vite",
    "build": "vite build",
    "lint": "eslint api lib shared src server-dev.ts vite.config.ts eslint.config.js --quiet",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@azure/openai": "^1.0.0-beta.12",
    "@google/genai": "^0.15.0",
    "@supabase/supabase-js": "^2.90.1",
    "@types/react-router-dom": "^5.3.3",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "express": "^5.1.0",
    "glob": "^11.0.3",
    "luxon": "^3.7.2",
    "node-cron": "^4.2.1",
    "pusher": "^5.3.2",
    "pusher-js": "^8.4.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.4",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.14.0",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "@typescript-eslint/parser": "^8.46.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "nodemon": "^3.1.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.60.0",
    "vercel": "^48.6.0",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
